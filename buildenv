BINUTILS_VERSION="2.46.0"

export ZOPEN_DEV_URL="git@github.com:gittup/binutils.git"
export ZOPEN_DEV_DEPS="git make autoconf"
export ZOPEN_STABLE_URL="https://ftp.gnu.org/gnu/binutils/binutils-${BINUTILS_VERSION}.tar.gz"
export ZOPEN_STABLE_DEPS="make"
export ZOPEN_BUILD_LINE="?"
export ZOPEN_CATEGORIES="development"
export ZOPEN_CONFIGURE_OPTS="--with-cc=\${CC} --with-ld-opt=\"\$LDFLAGS \$LIBS\" --with-cc-opt=\"\$CPPFLAGS \$CFLAGS\" "

zopen_check_results()
{
  dir="$1"
  pfx="$2"
  chk="$1/$2_check.log"
  grep "All tests passed"
}

zopen_append_to_env()
{
  # echo extra envars here:
}

zopen_append_to_zoslib_env()
{
  echo "envar|set|value"
}
